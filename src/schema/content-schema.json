{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "_notice": "이 파일은 IDE 자동완성 전용. runtime validate.ts에서 실행되지 않음. 실제 검증은 src/pipeline/validate.ts (Zod)가 담당. canonical 규칙은 REVISED_CANONICAL_SPEC.md 참조. v1.1.0 — Beat system + EvidenceCard 추가.",
  "title": "BookContent",
  "description": "Editorial Signal — 책 1권을 표현하는 콘텐츠 스키마. IDE 자동완성 전용. runtime 검증 기준이 아님.",
  "version": "1.1.0",
  "type": "object",
  "required": ["metadata", "narration", "scenes"],

  "properties": {
    "metadata": {
      "type": "object",
      "required": ["id", "title", "author", "genre"],
      "properties": {
        "id": {
          "type": "string",
          "description": "영상 고유 ID. 파일명과 일치 권장",
          "example": "book-2024-influence"
        },
        "title": { "type": "string", "example": "설득의 심리학" },
        "author": { "type": "string", "example": "로버트 치알디니" },
        "originalTitle": { "type": "string", "example": "Influence" },
        "genre": {
          "type": "string",
          "enum": [
            "selfHelp",
            "psychology",
            "business",
            "philosophy",
            "science",
            "ai"
          ]
        },
        "isbn": { "type": "string" },
        "coverImageUrl": {
          "type": "string",
          "description": "assets/covers/ 하위 파일명 또는 URL",
          "example": "covers/influence.png"
        },
        "publishYear": { "type": "integer" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "example": ["심리학", "설득", "마케팅"]
        },
        "channelNote": {
          "type": "string",
          "description": "편집 메모. 렌더에 영향 없음"
        }
      }
    },

    "production": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": ["longform", "shorts", "both"],
          "default": "both"
        },
        "targetDurationSeconds": {
          "type": "integer",
          "description": "longform 목표 길이 (초)",
          "default": 480
        },
        "fps": { "type": "integer", "default": 30 },
        "themeMode": {
          "type": "string",
          "enum": ["dark", "light"],
          "default": "dark"
        },
        "genreOverride": {
          "type": "string",
          "description": "metadata.genre를 overriding하고 싶을 때만 사용"
        }
      }
    },

    "narration": {
      "type": "object",
      "required": ["voice"],
      "properties": {
        "voice": {
          "type": "string",
          "description": "TTS 음성 ID",
          "example": "ko-KR-InJoonNeural"
        },
        "ttsEngine": {
          "type": "string",
          "enum": ["edge-tts", "elevenlabs", "google-tts", "minimax"],
          "default": "edge-tts"
        },
        "speed": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.7,
          "maximum": 1.4
        },
        "pitch": { "type": "string", "default": "+0Hz" },
        "subtitleMaxCharsPerLine": { "type": "integer", "default": 28 },
        "subtitleMaxLines": { "type": "integer", "default": 2 }
      }
    },

    "scenes": {
      "type": "array",
      "minItems": 3,
      "description": "씬 배열. 순서가 타임라인 순서. 각 씬은 layout archetype 기반 캔버스 배치.",
      "items": {
        "type": "object",
        "required": ["id", "type", "content"],
        "properties": {
          "id": {
            "type": "string",
            "description": "씬 고유 ID. 타입-번호 형식 권장",
            "example": "keyInsight-01"
          },
          "type": {
            "type": "string",
            "enum": [
              "cover",
              "chapterDivider",
              "keyInsight",
              "compareContrast",
              "quote",
              "framework",
              "application",
              "data",
              "closing"
            ]
          },
          "layoutArchetypeOverride": {
            "type": "string",
            "description": "기본 layout archetype 대신 alt를 사용하고 싶을 때",
            "enum": [
              "center-focus",
              "left-anchor",
              "split-compare",
              "grid-expand",
              "quote-hold",
              "map-flow",
              "top-anchor",
              "band-divider"
            ]
          },
          "durationFrames": {
            "type": "integer",
            "description": "명시하면 TTS 길이보다 우선. 생략하면 TTS 기반 자동 계산."
          },
          "motionPresetOverride": {
            "type": "string",
            "enum": ["gentle", "smooth", "snappy", "heavy", "dramatic"]
          },
          "narrationText": {
            "type": "string",
            "description": "이 씬의 VO 텍스트. TTS 입력값. 없으면 무음 씬."
          },
          "beats": {
            "type": "array",
            "description": "씬 내부 시간 구간 배열. 없으면 암묵적 단일 beat (기존 동작 유지).",
            "items": { "$ref": "#/definitions/BeatDefinition" }
          },
          "content": {
            "type": "object",
            "description": "씬 타입별로 다른 콘텐츠 객체",
            "oneOf": [
              { "$ref": "#/definitions/CoverContent" },
              { "$ref": "#/definitions/ChapterDividerContent" },
              { "$ref": "#/definitions/KeyInsightContent" },
              { "$ref": "#/definitions/CompareContrastContent" },
              { "$ref": "#/definitions/QuoteContent" },
              { "$ref": "#/definitions/FrameworkContent" },
              { "$ref": "#/definitions/ApplicationContent" },
              { "$ref": "#/definitions/DataContent" },
              { "$ref": "#/definitions/ClosingContent" }
            ]
          },
          "assets": {
            "type": "object",
            "description": "이 씬에서 사용하는 에셋 ID 참조 (asset-manifest.json 기준)",
            "properties": {
              "coverImage": { "type": "string" },
              "backgroundTexture": { "type": "string" },
              "icon": { "type": "string" },
              "bgm": { "type": "string" },
              "sfx": { "type": "string" }
            }
          },
          "shorts": {
            "type": "object",
            "description": "Shorts 포맷 전용 override. 없으면 기본 shorts adaptation 규칙 적용.",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "skipForShorts": { "type": "boolean", "default": false },
              "durationFramesOverride": { "type": "integer" },
              "beats": {
                "type": "array",
                "description": "Shorts 전용 beat 오버라이드. 없으면 longform beats 자동 압축.",
                "items": { "$ref": "#/definitions/BeatDefinition" }
              }
            }
          }
        }
      }
    },

    "audio": {
      "type": "object",
      "properties": {
        "bgmTrack": {
          "type": "string",
          "description": "assets/sounds/ 파일명",
          "example": "sounds/bgm-editorial-01.mp3"
        },
        "bgmVolume": {
          "type": "number",
          "default": 0.12,
          "minimum": 0,
          "maximum": 1
        },
        "sonicLogo": {
          "type": "string",
          "description": "아웃트로 브랜드 사운드 파일명"
        }
      }
    }
  },

  "definitions": {
    "CoverContent": {
      "type": "object",
      "required": ["title", "author", "coverImageUrl"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "author": { "type": "string" },
        "coverImageUrl": {
          "type": "string",
          "description": "assets/ 기준 상대경로. 예: covers/influence.png (assets/ prefix 없이)"
        },
        "brandLabel": { "type": "string", "example": "Editorial Signal" },
        "backgroundVariant": {
          "type": "string",
          "enum": ["dark", "light"],
          "default": "dark"
        }
      }
    },

    "ChapterDividerContent": {
      "type": "object",
      "required": ["chapterNumber", "chapterTitle"],
      "properties": {
        "chapterNumber": { "type": "integer", "minimum": 1 },
        "chapterTitle": { "type": "string" },
        "chapterSubtitle": { "type": "string" },
        "useAltLayout": { "type": "boolean", "default": false }
      }
    },

    "KeyInsightContent": {
      "type": "object",
      "required": ["headline"],
      "properties": {
        "headline": {
          "type": "string",
          "description": "핵심 주장 1문장. 50자 이내 권장."
        },
        "supportText": {
          "type": "string",
          "description": "보조 설명. 2줄 이내 권장."
        },
        "underlineKeyword": {
          "type": "string",
          "description": "headline 내에서 강조할 키워드"
        },
        "useSignalBar": { "type": "boolean", "default": true },
        "evidenceCard": { "$ref": "#/definitions/EvidenceCard" }
      }
    },

    "CompareContrastContent": {
      "type": "object",
      "required": ["leftLabel", "leftContent", "rightLabel", "rightContent"],
      "properties": {
        "leftLabel": { "type": "string", "example": "일반적 오해" },
        "leftContent": { "type": "string" },
        "rightLabel": { "type": "string", "example": "저자의 주장" },
        "rightContent": { "type": "string" },
        "leftTag": {
          "type": "string",
          "enum": ["before", "myth", "wrong", "common", "custom"]
        },
        "rightTag": {
          "type": "string",
          "enum": ["after", "fact", "right", "author", "custom"]
        },
        "showConnector": { "type": "boolean", "default": false },
        "revealOrder": {
          "type": "string",
          "enum": ["simultaneous", "left-first", "right-first"],
          "default": "left-first"
        }
      }
    },

    "QuoteContent": {
      "type": "object",
      "required": ["quoteText", "attribution"],
      "properties": {
        "quoteText": {
          "type": "string",
          "description": "인용문. 3줄 이내 권장."
        },
        "attribution": {
          "type": "string",
          "description": "— 저자명, 책 제목 형식"
        },
        "useSerif": { "type": "boolean", "default": true },
        "showTexture": { "type": "boolean", "default": true }
      }
    },

    "FrameworkContent": {
      "type": "object",
      "required": ["frameworkLabel", "items"],
      "properties": {
        "frameworkLabel": {
          "type": "string",
          "description": "프레임워크 이름. 예: '3가지 원칙'",
          "example": "설득의 6가지 무기"
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["number", "title"],
            "properties": {
              "number": { "type": "integer" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "iconId": { "type": "string" }
            }
          }
        },
        "showConnectors": { "type": "boolean", "default": false },
        "showDescriptions": { "type": "boolean", "default": true }
      }
    },

    "ApplicationContent": {
      "type": "object",
      "required": ["anchorStatement", "steps"],
      "properties": {
        "anchorStatement": {
          "type": "string",
          "description": "핵심 적용 문장. 예: '오늘 당장 써먹는 방법'"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["title"],
            "properties": {
              "title": { "type": "string" },
              "detail": { "type": "string" },
              "iconId": { "type": "string" }
            }
          }
        },
        "showPaths": { "type": "boolean", "default": true },
        "showCheckmarks": { "type": "boolean", "default": false }
      }
    },

    "DataContent": {
      "type": "object",
      "required": ["chartType", "dataLabel", "data"],
      "properties": {
        "chartType": {
          "type": "string",
          "enum": ["bar", "line", "compare", "stepFlow", "matrix"]
        },
        "dataLabel": { "type": "string" },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "number" },
              "highlight": { "type": "boolean" }
            }
          }
        },
        "annotation": { "type": "string" },
        "sourceCredit": { "type": "string" },
        "unit": { "type": "string", "example": "%" }
      }
    },

    "ClosingContent": {
      "type": "object",
      "required": ["recapStatement"],
      "properties": {
        "recapStatement": {
          "type": "string",
          "description": "핵심 회수 문장. 짧고 강하게."
        },
        "ctaText": { "type": "string" },
        "showBrandLabel": { "type": "boolean", "default": true }
      }
    },

    "BeatDefinition": {
      "type": "object",
      "required": ["id", "role", "startRatio", "endRatio", "activates"],
      "properties": {
        "id": {
          "type": "string",
          "description": "beat 고유 ID. 씬 내 유일."
        },
        "role": {
          "type": "string",
          "enum": [
            "hook",
            "headline",
            "support",
            "evidence",
            "reveal",
            "compare",
            "transition",
            "recap"
          ],
          "description": "의미론적 역할"
        },
        "startRatio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "endRatio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "narrationText": { "type": "string" },
        "activates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "deactivates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "emphasisTargets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "강조할 단어/구. activates와 별개 네임스페이스."
        },
        "motionPreset": {
          "type": "string",
          "enum": ["gentle", "smooth", "snappy", "heavy", "dramatic"]
        },
        "transition": {
          "type": "string",
          "enum": ["enter", "replace", "emphasis"],
          "default": "enter"
        }
      }
    },

    "EvidenceCard": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["statistic", "quote", "case", "research"],
          "description": "근거 카드 유형"
        },
        "value": {
          "type": "string",
          "description": "핵심 수치 또는 인용문"
        },
        "caption": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  },

  "validationRules": {
    "_notice": "이 섹션은 IDE 참고용. 실제 검증은 src/pipeline/validate.ts가 담당.",
    "sceneCount": {
      "longformMinimum": 5,
      "longformRecommended": "8–14",
      "shortsMinimum": 1,
      "shortsRecommended": "1–3"
    },
    "headlineMaxLength": 60,
    "narrationTextMaxLength": 200,
    "narrationTextRecommended": 120,
    "subtitleMaxCharsPerLine": 28,
    "subtitleMaxLines": 2,
    "quoteTextMaxLines": 3,
    "frameworkItemsMax": 5,
    "applicationStepsMax": 4,
    "coverImageRequired": true,
    "lastSceneMustBe": "closing (longform/both only)",
    "firstSceneMustBe": "cover (longform/both only)"
  }
}
