{
  "id": "cover-01",
  "intent": "Book cover reveal with title, author, and brand",
  "origin": "preset",
  "layout": "center-focus",
  "elements": [
    {
      "id": "cover-texture",
      "type": "texture-overlay",
      "props": {
        "layer": 5
      }
    },
    {
      "id": "cover-image",
      "type": "image",
      "props": {
        "src": "covers/crazy-one-year-cover.png",
        "layer": 25,
        "role": "book-cover"
      }
    },
    {
      "id": "cover-title",
      "type": "headline",
      "props": {
        "text": "딱 1년만 미쳐라",
        "layer": 30,
        "tokenRef": "typeScale.headlineL"
      }
    },
    {
      "id": "cover-subtitle",
      "type": "body-text",
      "props": {
        "text": "평범을 거부하는 1년의 전략",
        "layer": 20,
        "tokenRef": "typeScale.bodyM"
      }
    },
    {
      "id": "cover-author",
      "type": "body-text",
      "props": {
        "text": "강상구",
        "layer": 20,
        "tokenRef": "typeScale.bodyS"
      }
    },
    {
      "id": "cover-brandLabel",
      "type": "label",
      "props": {
        "text": "Editorial Signal",
        "layer": 40,
        "tokenRef": "typeScale.label"
      }
    }
  ],
  "choreography": "reveal-sequence",
  "motionPreset": "dramatic",
  "format": "longform",
  "theme": {
    "mode": "dark",
    "genre": "selfHelp",
    "bg": "#0F172A",
    "surface": "#1E293B",
    "surfaceMuted": "#334155",
    "textStrong": "#F8F7F2",
    "textMuted": "#94A3B8",
    "lineSubtle": "#334155",
    "signal": "#356DFF",
    "accent": "#10B981",
    "premium": "#D4A853"
  },
  "from": 0,
  "durationFrames": 1512,
  "mediaPlan": {
    "narrationText": "강상구의 딱 1년만 미쳐라. 평범한 삶을 거부하고, 단 1년의 집중으로 인생을 뒤바꾸는 실전 전략을 알아봅니다.",
    "captionPlan": {
      "mode": "sentence-by-sentence",
      "maxCharsPerLine": 28,
      "maxLines": 2,
      "leadFrames": 3,
      "trailFrames": 6,
      "transitionStyle": "fade-slide"
    },
    "audioPlan": {
      "ttsEngine": "edge-tts",
      "voiceKey": "ko-KR-SunHiNeural",
      "speed": 1,
      "pitch": "+0Hz"
    },
    "assetPlan": {
      "required": [],
      "fallbackMode": "text-only"
    }
  }
}