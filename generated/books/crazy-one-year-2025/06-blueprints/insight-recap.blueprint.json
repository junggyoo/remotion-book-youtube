{
  "id": "insight-recap",
  "intent": "Key insight headline reveal with optional support text",
  "origin": "preset",
  "layout": "center-focus",
  "elements": [
    {
      "id": "keyInsight-texture",
      "type": "texture-overlay",
      "props": {
        "layer": 5
      }
    },
    {
      "id": "keyInsight-signalBar",
      "type": "shape",
      "props": {
        "role": "signal-bar",
        "layer": 20,
        "tokenRef": "colors.signal"
      }
    },
    {
      "id": "keyInsight-headline",
      "type": "headline",
      "props": {
        "text": "미치면 세상이 기억한다",
        "layer": 30,
        "tokenRef": "typeScale.headlineL",
        "underlineKeyword": "미치면"
      }
    },
    {
      "id": "keyInsight-supportText",
      "type": "body-text",
      "props": {
        "text": "CRAZY 5단계로 1년을 무기로 만드세요. 자기인식, 준비, 점검, 그리고 전력 질주.",
        "layer": 25,
        "tokenRef": "typeScale.bodyM"
      }
    }
  ],
  "choreography": "reveal-sequence",
  "motionPreset": "heavy",
  "format": "longform",
  "theme": {
    "mode": "dark",
    "genre": "selfHelp",
    "bg": "#0F172A",
    "surface": "#1E293B",
    "surfaceMuted": "#334155",
    "textStrong": "#F8F7F2",
    "textMuted": "#94A3B8",
    "lineSubtle": "#334155",
    "signal": "#356DFF",
    "accent": "#10B981",
    "premium": "#D4A853"
  },
  "from": 0,
  "durationFrames": 1170,
  "mediaPlan": {
    "narrationText": "정리하겠습니다. 딱 1년만 미쳐라는 단순한 동기부여 책이 아닙니다. CRAZY라는 5단계 전략을 통해 1년이라는 시간을 무기로 바꾸는 실전 가이드입니다. 선언하고, 자기를 알고, 제대로 준비하고, 중간에 점검하며, 1년간 온전히 미쳐보세요. 행동하지 않으면 그 무엇도 얻을 수 없습니다. 미치지 않으면 아무도 당신을 기억하지 않습니다. 하지만 딱 1년만 미치면, 세상이 당신을 기억합니다.",
    "captionPlan": {
      "mode": "sentence-by-sentence",
      "maxCharsPerLine": 28,
      "maxLines": 2,
      "leadFrames": 3,
      "trailFrames": 6,
      "transitionStyle": "fade-slide"
    },
    "audioPlan": {
      "ttsEngine": "edge-tts",
      "voiceKey": "ko-KR-SunHiNeural",
      "speed": 1,
      "pitch": "+0Hz"
    },
    "assetPlan": {
      "required": [],
      "fallbackMode": "text-only"
    }
  }
