{
  "id": "insight-recap",
  "intent": "Key insight headline reveal with optional support text",
  "origin": "preset",
  "layout": "center-focus",
  "elements": [
    {
      "id": "keyInsight-texture",
      "type": "texture-overlay",
      "props": {
        "layer": 5
      }
    },
    {
      "id": "keyInsight-signalBar",
      "type": "shape",
      "props": {
        "role": "signal-bar",
        "layer": 20,
        "tokenRef": "colors.signal"
      }
    },
    {
      "id": "keyInsight-headline",
      "type": "headline",
      "props": {
        "text": "이성은 도구이지, 나침반이 아니다",
        "layer": 30,
        "tokenRef": "typeScale.headlineM",
        "underlineKeyword": "도구"
      }
    },
    {
      "id": "keyInsight-supportText",
      "type": "body-text",
      "props": {
        "text": "보르헤스는 이성을 맹신하는 인간의 오만을 경고합니다. 논리는 세계를 이해하는 도구이지, 세계 그 자체가 아닙니다.",
        "layer": 25,
        "tokenRef": "typeScale.bodyM"
      }
    }
  ],
  "choreography": "reveal-sequence",
  "motionPreset": "heavy",
  "format": "longform",
  "theme": {
    "mode": "dark",
    "genre": "philosophy",
    "bg": "#0F172A",
    "surface": "#1E293B",
    "surfaceMuted": "#334155",
    "textStrong": "#F8F7F2",
    "textMuted": "#94A3B8",
    "lineSubtle": "#334155",
    "signal": "#356DFF",
    "accent": "#6366F1",
    "premium": "#D4A853"
  },
  "from": 0,
  "durationFrames": 1560,
  "mediaPlan": {
    "narrationText": "정리하겠습니다. 밤과 나침반은 단순한 추리소설이 아닙니다. 80년 전에 쓰여진 이 짧은 단편이 지금도 읽히는 이유가 있습니다. 바로 이성의 한계에 대한 가장 날카로운 경고이기 때문입니다. 탐정 뢰넌은 자신의 논리가 완벽하다고 믿었습니다. 하지만 완벽한 논리가 완벽한 함정이 되었죠. 보르헤스는 묻습니다. 당신이 믿는 그 패턴은 진짜인가요, 아니면 당신이 보고 싶은 패턴인가요? 우리는 매일 패턴을 찾습니다. 주식 차트에서, 사람들의 행동에서, 세상의 흐름에서. 하지만 그 패턴이 진짜인지, 내가 만들어낸 환상인지 구별하기는 정말 어렵습니다. 이성은 세계를 이해하는 도구이지, 세계 그 자체가 아닙니다. 나침반을 믿되, 나침반이 가리키는 곳이 반드시 안전하리란 보장은 없습니다.",
    "captionPlan": {
      "mode": "sentence-by-sentence",
      "maxCharsPerLine": 28,
      "maxLines": 2,
      "leadFrames": 3,
      "trailFrames": 6,
      "transitionStyle": "fade-slide"
    },
    "audioPlan": {
      "ttsEngine": "edge-tts",
      "voiceKey": "ko-KR-SunHiNeural",
      "speed": 1,
      "pitch": "+0Hz"
    },
    "assetPlan": {
      "required": [],
      "fallbackMode": "text-only"
    }
  }
}