  "choreography": "reveal-sequence",
  "motionPreset": "dramatic",
  "format": "longform",
  "theme": {
    "mode": "dark",
    "genre": "business",
    "bg": "#0F172A",
    "surface": "#1E293B",
    "surfaceMuted": "#334155",
    "textStrong": "#F8F7F2",
    "textMuted": "#94A3B8",
    "lineSubtle": "#334155",
    "signal": "#356DFF",
    "accent": "#F59E0B",
    "premium": "#D4A853"
  },
  "from": 0,
  "durationFrames": 1404,
  "mediaPlan": {
    "narrationText": "도널드 밀러의 스토리 설계자. 전 세계 수만 개 기업의 매출을 바꾼 스토리 브랜드 프레임워크의 핵심을 정리합니다.",
