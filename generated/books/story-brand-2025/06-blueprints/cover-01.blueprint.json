{
  "id": "cover-01",
  "intent": "Book cover reveal with title, author, and brand",
  "origin": "preset",
  "layout": "center-focus",
  "elements": [
    {
      "id": "cover-texture",
      "type": "texture-overlay",
      "props": {
        "layer": 5
      }
    },
    {
      "id": "cover-image",
      "type": "image",
      "props": {
        "src": "covers/story-brand-cover.png",
        "layer": 25,
        "role": "book-cover"
      }
    },
    {
      "id": "cover-title",
      "type": "headline",
      "props": {
        "text": "스토리 설계자",
        "layer": 30,
        "tokenRef": "typeScale.headlineL"
      }
    },
    {
      "id": "cover-subtitle",
      "type": "body-text",
      "props": {
        "text": "고객을 영웅으로 만드는 7단계 브랜드 전략",
        "layer": 20,
        "tokenRef": "typeScale.bodyM"
      }
    },
    {
      "id": "cover-author",
      "type": "body-text",
      "props": {
        "text": "도널드 밀러",
        "layer": 20,
        "tokenRef": "typeScale.bodyS"
      }
    },
    {
      "id": "cover-brandLabel",
      "type": "label",
      "props": {
        "text": "Editorial Signal",
        "layer": 40,
        "tokenRef": "typeScale.label"
      }
    }
