{
  "id": "insight-recap",
  "intent": "Key insight headline reveal with optional support text",
  "origin": "preset",
  "layout": "center-focus",
  "elements": [
    {
      "id": "keyInsight-texture",
      "type": "texture-overlay",
      "props": {
        "layer": 5
      }
    },
    {
      "id": "keyInsight-signalBar",
      "type": "shape",
      "props": {
        "role": "signal-bar",
        "layer": 20,
        "tokenRef": "colors.signal"
      }
    },
    {
      "id": "keyInsight-headline",
      "type": "headline",
      "props": {
        "text": "도구는 단순하다, 시스템이 특별하다",
        "layer": 30,
        "tokenRef": "typeScale.headlineM",
        "underlineKeyword": "시스템"
      }
    },
    {
      "id": "keyInsight-supportText",
      "type": "body-text",
      "props": {
        "text": "명상, 공포 설정, 저널링, 스토아 철학. 도구는 단순합니다. 매일 반복하는 시스템이 타이탄을 만듭니다.",
        "layer": 25,
        "tokenRef": "typeScale.bodyM"
      }
    }
  ],
  "choreography": "reveal-sequence",
  "motionPreset": "heavy",
  "format": "longform",
  "theme": {
    "mode": "dark",
    "genre": "selfHelp",
    "bg": "#0F172A",
    "surface": "#1E293B",
    "surfaceMuted": "#334155",
    "textStrong": "#F8F7F2",
    "textMuted": "#94A3B8",
    "lineSubtle": "#334155",
    "signal": "#356DFF",
    "accent": "#10B981",
    "premium": "#D4A853"
  },
  "from": 0,
  "durationFrames": 1170,
  "mediaPlan": {
    "narrationText": "정리하겠습니다. 타이탄의 도구들은 700페이지가 넘는 두꺼운 책입니다. 하지만 핵심은 놀랍도록 단순합니다. 200명의 성공자가 서로 다른 분야에서 같은 도구를 씁니다. 아침 명상으로 마음을 비우고, 공포 설정으로 결정의 장벽을 무너뜨리고, 저널링으로 생각을 정리합니다. 스토아 철학으로 통제 가능한 것에만 집중합니다. 이 도구들은 하나도 특별하지 않습니다. 특별한 건 이걸 매일 반복하는 시스템을 만든 거죠.",
    "captionPlan": {
      "mode": "sentence-by-sentence",
      "maxCharsPerLine": 28,
      "maxLines": 2,
      "leadFrames": 3,
      "trailFrames": 6,
      "transitionStyle": "fade-slide"
    },
    "audioPlan": {
      "ttsEngine": "edge-tts",
      "voiceKey": "ko-KR-SunHiNeural",
      "speed": 1,
      "pitch": "+0Hz"
    },
    "assetPlan": {
      "required": [],
      "fallbackMode": "text-only"
    }
  }
}