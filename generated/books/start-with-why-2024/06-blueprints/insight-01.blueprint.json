        "underlineKeyword": "변연계"
      }
    },
    {
      "id": "keyInsight-supportText",
      "type": "body-text",
      "props": {
        "text": "신피질(neocortex)은 분석과 언어를, 변연계(limbic brain)는 감정과 의사결정을 담당합니다. Why는 변연계를 직접 자극합니다.",
        "layer": 25,
        "tokenRef": "typeScale.bodyM"
      }
    }
  ],
  "choreography": "reveal-sequence",
  "motionPreset": "heavy",
  "format": "longform",
  "theme": {
    "mode": "dark",
    "genre": "business",
    "bg": "#0F172A",
    "surface": "#1E293B",
    "surfaceMuted": "#334155",
    "textStrong": "#F8F7F2",
    "textMuted": "#94A3B8",
    "lineSubtle": "#334155",
    "signal": "#356DFF",
    "accent": "#F59E0B",
    "premium": "#D4A853"
  },
  "from": 0,
  "durationFrames": 1098,
  "mediaPlan": {
    "narrationText": "그런데 왜 Why가 이렇게 강력할까요? 여기에 놀라운 과학적 근거가 있습니다. 우리 뇌의 구조를 한번 들여다보면요... 가장 바깥쪽 신피질, neocortex는 분석과 언어를 담당합니다. What과 How에 해당하죠. 스펙을 비교하고, 기능을 나열하고, 가격을 따지는 영역입니다. 그런데 놀라운 건, 실제로 결정을 내리는 곳은 여기가 아니라는 겁니다! 뇌의 안쪽, 변연계 limbic brain이 감정과 의사결정을 담당합니다. 신뢰, 충성심, 모든 인간의 행동이 여기서 결정돼요. 그런데 이 영역에는 언어 능력이 없습니다. 그래서 우리가 뭔가를 깊이 느끼면서도 정확히 말로 설명하지 못하는 거예요. 그냥 느낌이 맞아, 라고 하죠. 직감이라는 게 바로 이겁니다. Why로 소통하면 바로 이 변연계를 직접 자극합니다. 사람들이 논리가 아니라 믿음으로 행동하게 만드는 겁니다. 이것이 Golden Circle의 생물학적 기반입니다.",
    "captionPlan": {
      "mode": "sentence-by-sentence",
      "maxCharsPerLine": 28,
      "maxLines": 2,
      "leadFrames": 3,
      "trailFrames": 6,
      "transitionStyle": "fade-slide"
    },
    "audioPlan": {
      "ttsEngine": "edge-tts",
      "voiceKey": "ko-KR-SunHiNeural",
      "speed": 1,
      "pitch": "+0Hz"
    },
    "assetPlan": {
      "required": [],
      "fallbackMode": "text-only"
    }
  }
}