  "motionPreset": "heavy",
  "format": "longform",
  "theme": {
    "mode": "dark",
    "genre": "business",
    "bg": "#0F172A",
    "surface": "#1E293B",
    "surfaceMuted": "#334155",
    "textStrong": "#F8F7F2",
    "textMuted": "#94A3B8",
    "lineSubtle": "#334155",
    "signal": "#356DFF",
    "accent": "#F59E0B",
    "premium": "#D4A853"
